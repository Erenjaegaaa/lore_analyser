# =============================================================================
# GraphRAG Lore Assistant — .gitignore
# =============================================================================


# ── Credentials ──────────────────────────────────────────────────────────────
.env


# ── Generated data (all reproducible by re-running the day runners) ──────────
data/raw/
data/cleaned/
data/chunks/
data/chroma_db/
logs/


# ── Keep these data files ─────────────────────────────────────────────────────
# data/evaluation/questions.json  ← hand-crafted, not reproducible — DO commit


# ── Python ───────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.pyc
*.egg
*.egg-info/
dist/
build/
.eggs/


# ── Virtual environments ──────────────────────────────────────────────────────
venv/
.venv/
env/
.env/


# ── IDE / editor ──────────────────────────────────────────────────────────────
.vscode/
.idea/
*.sublime-project
*.sublime-workspace


# ── OS ────────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db


# ── Testing & coverage ────────────────────────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/